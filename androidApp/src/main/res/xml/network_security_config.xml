<?xml version="1.0" encoding="utf-8"?>
<!-- Cleartext (plain HTTP) is permitted ONLY for the emulator's host-machine alias (10.0.2.2),
     where the dev backend runs. All other cleartext traffic stays blocked (API 28+ default). -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
